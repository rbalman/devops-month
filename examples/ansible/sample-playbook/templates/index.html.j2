<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <title>{{ site_name }}</title>
</head>
<body>
  <!-- Rendered per host from variables and gathered facts. -->
  <h1>{{ site_name }}</h1>
  <h2>{{ page_title }}</h2>
  <p><strong>Deployed by: flat playbook</strong></p>
  <p>Served by {{ inventory_hostname }} ({{ ansible_facts['default_ipv4']['address'] }})</p>
  <p>OS: {{ ansible_facts['distribution'] }} {{ ansible_facts['distribution_version'] }} - {{ ansible_facts['processor_vcpus'] }} vCPU</p>
  <p>worker_processes = {{ worker_processes }}</p>
</body>
</html>
